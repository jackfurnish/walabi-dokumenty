# WALABI Render Pipeline — Environment Variables
# Copy this file to .env.local and fill in your API key

# Anthropic API key — required for real AI pipeline
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the default model
# Default: claude-opus-4-6 (best quality for commercial output)
# Budget option: claude-haiku-4-5-20251001 (faster, cheaper, less nuanced)
ANTHROPIC_MODEL=claude-opus-4-6
